# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Model used for the critic (cheap + fast)
CRITIC_MODEL=llama-3.1-8b-instant

# Model used for generation (stronger reasoning)
GENERATION_MODEL=llama-3.3-70b-versatile

# Max self-healing retry loops before falling back to "I don't know"
MAX_RETRIES=2

# Chroma persistence directory (relative to backend/)
CHROMA_DIR=./chroma_store

# Where uploaded PDFs get chunked from
COLLECTION_NAME=self_healing_rag
